API_FOOTBALL_KEY=your_rapidapi_key
# GET /fixtures?date= (puente event_id digest ↔ fixture API-Football); caché + cupo diario UTC.
API_FOOTBALL_FIXTURES_DAILY_CAP=25
# Cuotas por fixture (v3.football.api-sports.io/odds); caché + cupo diario UTC aparte del resto.
API_FOOTBALL_ODDS_DAILY_CAP=30
FOOTBALL_DATA_TOKEN=your_football_data_token
# Máximo de peticiones HTTP reales a football-data.org por día (UTC); repetir URL acierta en caché sin gastar cupo.
FOOTBALL_DATA_DAILY_CAP=90
# Descargas CSV gratuitas desde football-data.co.uk (sin token); cupo diario para no abusar del servidor.
FD_CO_UK_DOWNLOAD_DAILY_CAP=40
# The Odds API (https://the-odds-api.com/) plan gratuito: clave + cupo mensual conservador.
THE_ODDS_API_KEY=
THE_ODDS_API_MONTHLY_CAP=450
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# true = un mensaje con botones (agenda / Libertadores / Champions / …); en paralelo ejecuta: python -m src.free_digest_app --menu-bot
TELEGRAM_DIGEST_MENU=false
# Windows: ejecutá una vez scripts\windows\instalar_betfree_autostart_completo.bat (menú sin ventana al iniciar sesión + digest diario a las 08:30, configurable).
# Inicio silencioso del menú-bot: si true envía Telegram al arrancar (por defecto off). Log: data/logs/menu_bot.log
MENU_BOT_NOTIFY_ON_START=false
# MENU_BOT_LOG_PATH=data/logs/menu_bot.log
SQLITE_DB_PATH=betfree.db
# Histórico para Poisson+Elo y para preparar features del modelo E0 (competition E0 = PL en historical_robust).
HISTORICAL_CSV_PATH=data/open_datasets/historical_robust.csv
# true = tras cada digest escribe data/digest_live_evaluation.json (audit vs CSV).
DIGEST_RUN_LIVE_EVAL_AFTER_DIGEST=false
DIGEST_LIVE_EVAL_SINCE_DAYS=120
DIGEST_LIVE_EVAL_MIN_MATCHED=15
DIGEST_LIVE_EVAL_WARN_LOG_LOSS=1.08
# true = si el log-loss supera el umbral con suficientes partidos, INSERT en model_health_alerts (máx. 1/día UTC por fuente).
DIGEST_LIVE_EVAL_ALERT_ON_BREACH=false
# false = solo Poisson+Elo en 1X2 (también si falta el .pkl).
DIGEST_USE_E0_ML=true
# Ruta al artefacto joblib (relativa al repo o absoluta).
E0_EXPERT_MODEL_PATH=models/e0_expert_calibrated.pkl
# 0–1: fracción del modelo tabular E0 en 1X2; el resto es Poisson+Elo desde el CSV (por defecto 0.72 = mezcla más estable).
DIGEST_E0_ML_BLEND_WEIGHT=
# Ligera corrección del empate en Poisson (~1.03–1.06 típico); 1.0 = sin tocar.
DIGEST_POISSON_DRAW_FACTOR=
# true tras generar recommendations: python -m src.predictor.e0_blend_calibration
DIGEST_USE_BLEND_CALIBRATION_JSON=false
DIGEST_BLEND_CALIBRATION_PATH=data/e0_blend_calibration.json
# false = oculta la línea de confianza 1X2 en cada pronóstico Telegram.
DIGEST_SHOW_RELIABILITY_HINT=true
# true = Poisson+Elo aislado por competición del CSV (E0, SP1, …) si hay al menos N partidos históricos.
DIGEST_PER_LEAGUE_POISSON=true
DIGEST_PER_LEAGUE_MIN_ROWS=220
REQUEST_TIMEOUT_SECONDS=20
MIN_REQUEST_INTERVAL_SECONDS=1.2
# Opcional: lista separada por comas de slugs ESPN (ej. eng.1,esp.1,col.1). Vacío = lista por defecto (primera división + copas país + UEFA/CONMEBOL).
FREE_ESPN_SOCCER_SLUGS=
# Slugs ESPN de copas extra (coma-separados). Se fusionan con la lista anterior y pasan el filtro FIRST_DIVISION_ONLY (útil si ESPN añade Taça Portugal u otra).
FREE_ESPN_EXTRA_CUP_SLUGS=
# Si es true (por defecto), en la agenda solo entran slugs xxx.1, torneos uefa.* / conmebol.* y copas admitidas (lista por código + FREE_ESPN_EXTRA_CUP_SLUGS).
FREE_ESPN_FIRST_DIVISION_ONLY=true
# Radio en días alrededor de "hoy" para pedir scoreboards ESPN (±N). Ayuda si ESPN agrupa la fecha distinto al calendario local.
FIXTURE_DIGEST_FETCH_DAY_RADIUS=2
# Equipos cuya fecha debe aparecer antes en la agenda si hay que recortar por límite (coma-separados, subcadena sin distinguir mayúsculas).
FIXTURE_DIGEST_TEAM_PRIORITY=
# TheSportsDB (gratis): amplía la agenda con 1ª división mundial (intDivision=1, sin copas). Clave pública por defecto "3"; pon la tuya si TheSportsDB te asigna otra.
THESPORTSDB_API_KEY=
# false = solo ESPN (slugs de .env).
DIGEST_USE_THESPORTSDB=true
# Slugs ESPN extra (1ª división): solo “hoy” local. Vacío en .env = lista por defecto (~30 países). Coma-separados para sustituir.
FREE_ESPN_GLOBAL_TIER1_SLUGS=
# false = no pedir esas ligas extra (solo FREE_ESPN_SOCCER_SLUGS con su radio de días).
DIGEST_FETCH_GLOBAL_ESPN_TODAY=true
# true = agenda TheSportsDB solo Europa + Sudamérica y copas UEFA/CONMEBOL/FIFA CWC (sin AFC/CAF/CONCACAF).
DIGEST_TSDB_EU_SA_ONLY=true
# true = descarta slugs ESPN tipo usa.1, mex.1, afc.* aunque los pongas en FREE_ESPN_SOCCER_SLUGS.
DIGEST_ESPN_EU_SA_ONLY=true
# true (defecto) = Libertadores/Sudamericana + UEFA/FIFA clubes + ligas CHI ARG BRA ESP ENG FRA al frente si falta cupo en agenda/pronósticos.
DIGEST_FORCE_FIRST_PRIORITY=true
# Slugs ESPN extra para ese frente (coma-separadas). Vacío = chi.1,arg.1,bra.1,esp.1,eng.1,fra.1 (conmebol./uefa./fifa. siempre incluidos por prefijo).
DIGEST_FORCE_FIRST_ES_SLUGS=
# Máximo de partidos en la agenda del día (fusionados por ESPN).
DAILY_DIGEST_MAX_FIXTURES=900
# Máximo de bloques de pronóstico (mismo orden que la agenda). Vacío u omitido = mismo valor que DAILY_DIGEST_MAX_FIXTURES (si ponías 1 aquí solo veías un partido).
DAILY_DIGEST_MAX_PREDICTION_MESSAGES=
# Reservado (digest ya pronostica todos los partidos del tope anterior). Lista legacy por si se reutiliza.
PREDICTION_DETAIL_SLUGS=
